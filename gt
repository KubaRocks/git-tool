#!/usr/bin/env bash
set -uo pipefail

# gt — Git Tool CLI
# Streamlines the git branch-commit-push workflow with AI-generated commit messages.

GT_VERSION="v2026.03.13"

# ── Colors & Styles ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Helpers ──────────────────────────────────────────────────────────────────
die() { echo -e "${RED}error:${RESET} $*" >&2; exit 1; }
info() { echo -e "${BLUE}▸${RESET} $*"; }
success() { echo -e "${GREEN}✓${RESET} $*"; }
warn() { echo -e "${YELLOW}⚠${RESET} $*"; }

# ── Dependency Check ─────────────────────────────────────────────────────────
check_deps() {
  local missing=0
  if ! command -v gum &>/dev/null; then
    echo -e "${RED}Missing dependency: gum${RESET}"
    echo "  Install: brew install gum  (or see https://github.com/charmbracelet/gum)"
    missing=1
  fi
  if ! command -v claude &>/dev/null; then
    echo -e "${RED}Missing dependency: claude${RESET}"
    echo "  Install: see https://docs.anthropic.com/en/docs/claude-cli"
    missing=1
  fi
  [[ $missing -eq 1 ]] && exit 1
}

# ── Git Guards ───────────────────────────────────────────────────────────────
assert_git_repo() {
  git rev-parse --is-inside-work-tree &>/dev/null || die "Not a git repository."
}

assert_remote_origin() {
  git remote get-url origin &>/dev/null || die "No remote 'origin' configured."
}

assert_not_detached() {
  local head
  head=$(git symbolic-ref --short HEAD 2>/dev/null) || die "HEAD is detached. Create or switch to a branch first."
}

# ── Ticket ID Extraction ────────────────────────────────────────────────────
extract_ticket_id() {
  local input="$1"
  if [[ "$input" =~ ([A-Z]+-[0-9]+) ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

# ── gt branch ────────────────────────────────────────────────────────────────
cmd_branch() {
  assert_git_repo
  assert_remote_origin

  # 1. Detect default branch
  local default_branch
  default_branch=$(git remote show origin 2>/dev/null | grep 'HEAD branch' | awk '{print $NF}')
  [[ -z "$default_branch" ]] && die "Could not detect default branch from origin."
  info "Default branch: ${BOLD}${default_branch}${RESET}"

  # 2. Stash if dirty
  local stashed=0
  if [[ -n $(git status --porcelain) ]]; then
    info "Stashing uncommitted changes..."
    git stash push -m "gt-auto-stash"
    stashed=1
  fi

  # 3. Switch to default branch and pull
  info "Switching to ${BOLD}${default_branch}${RESET} and pulling latest..."
  git checkout "$default_branch"
  git pull

  # 4. Prompt for branch name
  local raw_name
  raw_name=$(gum input --placeholder "Branch name (e.g. NI-4567 refactor order flow)")
  [[ -z "$raw_name" ]] && die "No branch name provided."

  # 5. Convert to valid branch name
  local ticket_id branch_name
  ticket_id=$(extract_ticket_id "$raw_name")

  # Strip ticket ID from the rest for lowercasing
  local rest="$raw_name"
  if [[ -n "$ticket_id" ]]; then
    rest="${raw_name:${#ticket_id}}"
  fi

  # Lowercase the rest, replace spaces/invalid chars with dashes
  rest=$(echo "$rest" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._/-]/-/g' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//')

  if [[ -n "$ticket_id" ]]; then
    branch_name="${ticket_id}-${rest}"
  else
    branch_name="$rest"
  fi

  # Clean up trailing dashes
  branch_name=$(echo "$branch_name" | sed 's/-$//')

  [[ -z "$branch_name" ]] && die "Could not derive a valid branch name."
  info "Creating branch: ${BOLD}${branch_name}${RESET}"

  # 6. Create and switch to new branch
  git checkout -b "$branch_name"

  # 7. Pop stash if needed
  if [[ $stashed -eq 1 ]]; then
    info "Restoring stashed changes..."
    if ! git stash pop; then
      warn "Merge conflicts occurred while restoring stashed changes."
      warn "Resolve conflicts manually, then run: git stash drop"
    fi
  fi

  success "On new branch ${BOLD}${branch_name}${RESET}"
}

# ── gt push ──────────────────────────────────────────────────────────────────
cmd_push() {
  assert_git_repo
  assert_remote_origin
  assert_not_detached

  local branch
  branch=$(git symbolic-ref --short HEAD)

  # 1. Detect changes
  local status_output
  status_output=$(git status --porcelain)

  if [[ -z "$status_output" ]]; then
    # 2. No changes — check for unpushed commits
    local unpushed
    unpushed=$(git log --oneline "@{upstream}..HEAD" 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$unpushed" -gt 0 ]]; then
      local choice
      choice=$(gum choose "Yes" "Abort" --header "No changes to commit. Push ${unpushed} unpushed commit(s)?")
      if [[ "$choice" == "Yes" ]]; then
        push_branch "$branch"
        return
      else
        info "Aborted."
        return
      fi
    else
      die "No changes to commit and no unpushed commits."
    fi
  fi

  # 3. Interactive file staging — build display labels with status icons
  local files=()
  local labels=()
  while IFS= read -r line; do
    local status="${line:0:2}"
    local fname="${line:3}"
    files+=("$fname")

    local tag
    case "$status" in
      " M"|"M "|"MM") tag="modified" ;;
      " D"|"D ")       tag="deleted" ;;
      "??")            tag="new" ;;
      " A"|"A ")       tag="added" ;;
      " R"|"R ")       tag="renamed" ;;
      " C"|"C ")       tag="copied" ;;
      *)               tag="changed" ;;
    esac
    labels+=("${fname} (${tag})")
  done <<< "$status_output"

  local choices=("All files")
  choices+=("${labels[@]}")

  local selected
  selected=$(gum choose --no-limit --selected="All files" --header "Select files to stage:" -- "${choices[@]}") || die "File selection cancelled."

  [[ -z "$selected" ]] && die "No files selected. Aborting."

  if echo "$selected" | grep -q "^All files$"; then
    git add -A
    info "Staged all files."
  else
    # Extract filenames back from the selected labels — strip trailing " (tag)"
    while IFS= read -r label; do
      local file="${label% (*}"
      git add -- "$file"
    done <<< "$selected"
    local count
    count=$(echo "$selected" | wc -l | tr -d ' ')
    info "Staged ${count} file(s)."
  fi

  # 4. Check that we have a non-empty diff
  local diff_output
  diff_output=$(git diff --staged)
  if [[ -z "$diff_output" ]]; then
    warn "Staged diff is empty. Nothing to commit."
    git reset HEAD -- . &>/dev/null
    return
  fi

  # Generate commit message (with retry loop)
  local commit_msg
  while true; do
    commit_msg=$(cmd_message)
    [[ -z "$commit_msg" ]] && die "Failed to generate commit message."

    echo ""
    echo -e "${BOLD}Commit message:${RESET}"
    echo -e "${DIM}─────────────────────────────────────────${RESET}"
    echo "$commit_msg"
    echo -e "${DIM}─────────────────────────────────────────${RESET}"
    echo ""

    local action
    action=$(gum choose "Accept" "Edit" "Regenerate" "Cancel" --header "What would you like to do?")

    case "$action" in
      Accept)
        break
        ;;
      Edit)
        local tmpfile
        tmpfile=$(mktemp /tmp/gt-commit-msg.XXXXXX)
        echo "$commit_msg" > "$tmpfile"
        ${EDITOR:-vi} "$tmpfile"
        commit_msg=$(cat "$tmpfile")
        rm -f "$tmpfile"
        [[ -z "$commit_msg" ]] && die "Empty commit message. Aborting."
        break
        ;;
      Regenerate)
        info "Regenerating commit message..."
        continue
        ;;
      Cancel)
        info "Unstaging files..."
        git reset HEAD -- . &>/dev/null
        info "Aborted."
        return
        ;;
    esac
  done

  # 6. Pull remote changes before committing (rebase to keep history clean)
  if git rev-parse --verify --quiet "@{upstream}" &>/dev/null; then
    local remote_ahead
    remote_ahead=$(git rev-list --count "HEAD..@{upstream}" 2>/dev/null || echo "0")
    if [[ "$remote_ahead" -gt 0 ]]; then
      info "Pulling ${remote_ahead} remote change(s) before commit..."
      git stash push -m "gt-pre-pull-stash" --keep-index
      if ! git pull --rebase; then
        warn "Pull failed. Restoring your changes..."
        git rebase --abort 2>/dev/null
        git stash pop
        die "Could not pull remote changes. Resolve manually."
      fi
      git stash pop 2>/dev/null || true
    fi
  fi

  # 7. Commit
  git commit -m "$commit_msg"
  success "Committed."

  # 8. Push
  push_branch "$branch"
}

# ── gt message ───────────────────────────────────────────────────────────────
cmd_message() {
  assert_git_repo

  local branch_name
  branch_name=$(git branch --show-current)

  local jira_id
  jira_id=$(echo "$branch_name" | grep -oE '[A-Z]+-[0-9]+' | head -n 1 || true)

  # Get staged changes, fall back to unstaged
  local staged_diff unstaged_diff diff_to_analyze
  staged_diff=$(git diff --cached)
  unstaged_diff=$(git diff)

  if [[ -n "$staged_diff" ]]; then
    diff_to_analyze="$staged_diff"
  elif [[ -n "$unstaged_diff" ]]; then
    diff_to_analyze="$unstaged_diff"
  else
    echo "error: No changes to summarize" >&2
    return 1
  fi

  # Recent commits for style context
  local recent_commits
  recent_commits=$(git log --oneline -5 2>/dev/null || true)

  local prompt="Generate a concise git commit message based on the diff below.

CRITICAL: Your response must contain ONLY the commit message itself - no explanations, no preamble, no code blocks, no markdown formatting.

Requirements:
- Single line, 1-2 sentences maximum
- Start with lowercase verb (add/fix/update/refactor/remove)
- Focus on what changed and why
- Be specific and concise
- Do NOT include any ticket/issue prefixes (like JIRA-123)
- Do NOT use markdown or code formatting

Recent commits for style reference:
${recent_commits}

Changes to summarize:
${diff_to_analyze}"

  local raw_output
  raw_output=$(claude --model haiku "$prompt" 2>/dev/null) || {
    echo "error: Claude CLI failed" >&2
    return 1
  }

  # Clean up the output
  local commit_message
  commit_message=$(echo "$raw_output" | \
    grep -v -i -E '(here|based on|following|git diff|commit message:)' | \
    grep -v '```' | \
    sed -E 's/^[A-Z]+-[0-9]+:[[:space:]]*//' | \
    grep -v '^[[:space:]]*$' | \
    awk 'length > 20' | \
    head -n 1 | \
    sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | \
    sed 's/^`*//;s/`*$//')

  # Fallback: first non-empty line
  if [[ -z "$commit_message" ]]; then
    commit_message=$(echo "$raw_output" | grep -v '^[[:space:]]*$' | head -n 1 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
  fi

  # Prefix with Jira ID if found
  if [[ -n "$jira_id" ]]; then
    commit_message="${jira_id}: ${commit_message}"
  fi

  # Output: no trailing newline if piped
  if [[ -t 1 ]]; then
    echo "$commit_message"
  else
    printf "%s" "$commit_message"
  fi
}

# ── gt rebase ────────────────────────────────────────────────────────────────
cmd_rebase() {
  assert_git_repo
  assert_remote_origin
  assert_not_detached

  local branch
  branch=$(git symbolic-ref --short HEAD)

  # Detect default branch
  local default_branch
  default_branch=$(git remote show origin 2>/dev/null | grep 'HEAD branch' | awk '{print $NF}')
  [[ -z "$default_branch" ]] && die "Could not detect default branch from origin."

  [[ "$branch" == "$default_branch" ]] && die "Already on ${default_branch}. Switch to a feature branch first."

  # Fetch latest
  info "Fetching latest ${BOLD}${default_branch}${RESET}..."
  git fetch origin "$default_branch"

  # Check if rebase is needed
  local behind
  behind=$(git rev-list --count "HEAD..origin/${default_branch}")
  if [[ "$behind" -eq 0 ]]; then
    success "Already up to date with ${BOLD}${default_branch}${RESET}."
    return
  fi

  # Auto-stash if dirty
  local stashed=0
  if [[ -n $(git status --porcelain) ]]; then
    info "Stashing uncommitted changes..."
    git stash push -m "gt-auto-stash-rebase"
    stashed=1
  fi

  info "Rebasing ${BOLD}${branch}${RESET} onto ${BOLD}origin/${default_branch}${RESET} (${behind} new commit(s))..."

  # Attempt rebase
  if git rebase "origin/${default_branch}"; then
    success "Rebased successfully onto ${BOLD}${default_branch}${RESET}."
    if [[ $stashed -eq 1 ]]; then
      info "Restoring stashed changes..."
      if ! git stash pop; then
        warn "Conflicts while restoring stashed changes. Resolve manually, then: git stash drop"
      fi
    fi
  else
    # Conflicts detected
    warn "Rebase conflicts detected."
    echo ""

    local conflict_files
    conflict_files=$(git diff --name-only --diff-filter=U 2>/dev/null)
    if [[ -z "$conflict_files" ]]; then
      conflict_files=$(git status --porcelain | grep '^UU\|^AA\|^DU\|^UD' | awk '{print $2}')
    fi

    if [[ -n "$conflict_files" ]]; then
      echo -e "${BOLD}Conflicting files:${RESET}"
      echo "$conflict_files" | while IFS= read -r f; do
        echo -e "  ${RED}•${RESET} $f"
      done
      echo ""
    fi

    local tool
    tool=$(gum choose "Claude Code" "Codex" "Abort rebase" --header "Resolve conflicts with:")

    local resolve_prompt="You are in the middle of a git rebase of branch '${branch}' onto 'origin/${default_branch}'.

The following files have merge conflicts:
${conflict_files}

Resolve all merge conflicts in these files. Look at the conflict markers (<<<<<<< HEAD, =======, >>>>>>> ...) and choose the correct resolution by understanding both sides. After resolving, stage the files with 'git add' and run 'git rebase --continue'. If further conflicts arise, resolve those too until the rebase completes. Prefer the incoming changes but preserve new functionality from the feature branch."

    case "$tool" in
      "Claude Code")
        info "Launching Claude Code to resolve conflicts..."
        claude "$resolve_prompt"
        if [[ $stashed -eq 1 ]]; then
          info "Restoring stashed changes..."
          git stash pop || warn "Conflicts while restoring stash. Resolve manually, then: git stash drop"
        fi
        ;;
      "Codex")
        info "Launching Codex to resolve conflicts..."
        codex "$resolve_prompt"
        if [[ $stashed -eq 1 ]]; then
          info "Restoring stashed changes..."
          git stash pop || warn "Conflicts while restoring stash. Resolve manually, then: git stash drop"
        fi
        ;;
      "Abort rebase")
        git rebase --abort 2>/dev/null
        info "Rebase aborted. Branch is unchanged."
        if [[ $stashed -eq 1 ]]; then
          info "Restoring stashed changes..."
          git stash pop || warn "Conflicts while restoring stash. Resolve manually, then: git stash drop"
        fi
        ;;
    esac
  fi
}

# ── gt status ────────────────────────────────────────────────────────────────
cmd_status() {
  assert_git_repo
  assert_not_detached

  local branch
  branch=$(git symbolic-ref --short HEAD)

  local ticket_id
  ticket_id=$(extract_ticket_id "$branch")

  local dirty
  dirty=$(git status --porcelain | wc -l | tr -d ' ')

  local unpushed
  if git rev-parse --verify --quiet "@{upstream}" &>/dev/null; then
    unpushed=$(git log --oneline "@{upstream}..HEAD" 2>/dev/null | wc -l | tr -d ' ')
  else
    unpushed="—"
  fi

  local last_commit
  last_commit=$(git log -1 --pretty=format:'%s' 2>/dev/null || echo "(no commits)")

  echo ""
  echo -e "${BOLD}Branch:${RESET}    ${CYAN}${branch}${RESET}"
  if [[ -n "$ticket_id" ]]; then
    echo -e "${BOLD}Ticket:${RESET}    ${YELLOW}${ticket_id}${RESET}"
  fi
  echo -e "${BOLD}Dirty:${RESET}     ${dirty} file(s)"
  echo -e "${BOLD}Unpushed:${RESET}  ${unpushed} commit(s)"
  echo -e "${BOLD}Last:${RESET}      ${DIM}${last_commit}${RESET}"
  echo ""
}

# ── gt cleanup ────────────────────────────────────────────────────────────────
cmd_cleanup() {
  assert_git_repo
  assert_remote_origin
  assert_not_detached

  local branch
  branch=$(git symbolic-ref --short HEAD)

  # Detect default branch from remote
  local default_branch
  default_branch=$(git remote show origin 2>/dev/null | grep 'HEAD branch' | awk '{print $NF}')
  [[ -z "$default_branch" ]] && die "Could not detect default branch from origin."

  # Fetch and prune to sync remote state
  info "Fetching and pruning remote references..."
  git fetch --prune

  # Use the remote ref for merge checks — local default branch may be stale
  local remote_default="origin/${default_branch}"

  # Get merged branches (excluding default)
  local merged_branches=()
  while IFS= read -r b; do
    [[ -z "$b" ]] && continue
    [[ "$b" == "$default_branch" ]] && continue
    merged_branches+=("$b")
  done < <(git branch --merged "$remote_default" --format='%(refname:short)')

  # Get all local branches (excluding default)
  local all_branches=()
  while IFS= read -r b; do
    [[ -z "$b" ]] && continue
    [[ "$b" == "$default_branch" ]] && continue
    all_branches+=("$b")
  done < <(git branch --format='%(refname:short)')

  # Categorize branches
  local safe_to_delete=()
  local merged_remote_exists=()
  local unmerged_remote_gone=()

  for b in "${all_branches[@]}"; do
    local is_merged=0
    for m in "${merged_branches[@]}"; do
      if [[ "$b" == "$m" ]]; then
        is_merged=1
        break
      fi
    done

    # Detect squash merges: create a temp squash commit and check
    # if its patch-id already exists in the default branch
    if [[ $is_merged -eq 0 ]]; then
      local mb sq
      mb=$(git merge-base "$remote_default" "$b" 2>/dev/null || true)
      if [[ -n "$mb" ]]; then
        sq=$(git commit-tree "${b}^{tree}" -p "$mb" -m "temp" 2>/dev/null || true)
        if [[ -n "$sq" ]] && ! git cherry "$remote_default" "$sq" 2>/dev/null | grep -q "^+"; then
          is_merged=1
        fi
      fi
    fi

    local remote_exists=0
    if git rev-parse --verify --quiet "refs/remotes/origin/${b}" &>/dev/null; then
      remote_exists=1
    fi

    if [[ $is_merged -eq 1 && $remote_exists -eq 0 ]]; then
      safe_to_delete+=("$b")
    elif [[ $is_merged -eq 1 && $remote_exists -eq 1 ]]; then
      merged_remote_exists+=("$b")
    elif [[ $is_merged -eq 0 && $remote_exists -eq 0 ]]; then
      unmerged_remote_gone+=("$b")
    fi
    # Not merged + remote exists = active, skip
  done

  local total=$(( ${#safe_to_delete[@]} + ${#merged_remote_exists[@]} + ${#unmerged_remote_gone[@]} ))

  if [[ $total -eq 0 ]]; then
    success "Nothing to clean up. All branches look active."
    return
  fi

  # Display summary
  echo ""
  echo -e "${BOLD}Branch cleanup summary:${RESET}"
  echo -e "  ${GREEN}Safe to delete (merged, remote gone):${RESET}    ${#safe_to_delete[@]}"
  echo -e "  ${YELLOW}Merged but remote exists:${RESET}                ${#merged_remote_exists[@]}"
  echo -e "  ${RED}Unmerged but remote gone:${RESET}                ${#unmerged_remote_gone[@]}"
  echo ""

  local deleted=0

  # Helper: switch to default branch if we're about to delete the current one
  _ensure_not_on_branch() {
    local target="$1"
    if [[ "$(git symbolic-ref --short HEAD)" == "$target" ]]; then
      info "Switching to ${BOLD}${default_branch}${RESET} before deleting current branch..."
      git checkout "$default_branch" &>/dev/null
      git pull --ff-only &>/dev/null || true
    fi
  }

  # Category 1: Safe to delete (merged + remote gone)
  if [[ ${#safe_to_delete[@]} -gt 0 ]]; then
    echo -e "${GREEN}${BOLD}── Safe to delete (merged, remote gone) ──${RESET}"
    local selected_csv
    selected_csv=$(printf "%s," "${safe_to_delete[@]}")
    selected_csv="${selected_csv%,}"

    local chosen
    chosen=$(printf "%s\n" "${safe_to_delete[@]}" | gum choose --no-limit --selected="$selected_csv" --header "Select branches to delete:") || true

    if [[ -n "$chosen" ]]; then
      while IFS= read -r b; do
        [[ -z "$b" ]] && continue
        _ensure_not_on_branch "$b"
        if git branch -D "$b" &>/dev/null; then
          info "Deleted ${BOLD}${b}${RESET}"
          deleted=$(( deleted + 1 ))
        else
          warn "Failed to delete ${BOLD}${b}${RESET}"
        fi
      done <<< "$chosen"
    fi
    echo ""
  fi

  # Category 2: Merged but remote still exists
  if [[ ${#merged_remote_exists[@]} -gt 0 ]]; then
    echo -e "${YELLOW}${BOLD}── Merged but remote still exists ──${RESET}"
    for b in "${merged_remote_exists[@]}"; do
      local action
      action=$(gum choose "Delete local only" "Delete local + remote" "Skip" --header "Branch: ${b}") || true

      case "$action" in
        "Delete local only")
          _ensure_not_on_branch "$b"
          if git branch -D "$b" &>/dev/null; then
            info "Deleted local ${BOLD}${b}${RESET}"
            deleted=$(( deleted + 1 ))
          else
            warn "Failed to delete ${BOLD}${b}${RESET}"
          fi
          ;;
        "Delete local + remote")
          _ensure_not_on_branch "$b"
          if git branch -D "$b" &>/dev/null; then
            info "Deleted local ${BOLD}${b}${RESET}"
            deleted=$(( deleted + 1 ))
          else
            warn "Failed to delete local ${BOLD}${b}${RESET}"
          fi
          if git push origin --delete "$b" &>/dev/null; then
            info "Deleted remote ${BOLD}origin/${b}${RESET}"
          else
            warn "Failed to delete remote ${BOLD}origin/${b}${RESET}"
          fi
          ;;
        *)
          ;;
      esac
    done
    echo ""
  fi

  # Category 3: Unmerged but remote gone
  if [[ ${#unmerged_remote_gone[@]} -gt 0 ]]; then
    echo -e "${RED}${BOLD}── Unmerged but remote gone (caution) ──${RESET}"
    # Build labels with commit counts; keep parallel array for name lookup
    local labels=()
    local label_branches=()
    for b in "${unmerged_remote_gone[@]}"; do
      local ahead
      ahead=$(git rev-list --count "${remote_default}..${b}" 2>/dev/null || echo "?")
      labels+=("${b} (${ahead} commits ahead)")
      label_branches+=("$b")
    done

    local chosen
    chosen=$(printf "%s\n" "${labels[@]}" | gum choose --no-limit --header "Select branches to force-delete:") || true

    if [[ -n "$chosen" ]]; then
      while IFS= read -r label; do
        [[ -z "$label" ]] && continue
        # Find matching branch from parallel array
        local b=""
        for i in "${!labels[@]}"; do
          if [[ "${labels[$i]}" == "$label" ]]; then
            b="${label_branches[$i]}"
            break
          fi
        done
        [[ -z "$b" ]] && continue
        _ensure_not_on_branch "$b"
        if git branch -D "$b" &>/dev/null; then
          info "Force-deleted ${BOLD}${b}${RESET}"
          deleted=$(( deleted + 1 ))
        else
          warn "Failed to delete ${BOLD}${b}${RESET}"
        fi
      done <<< "$chosen"
    fi
    echo ""
  fi

  # Final summary
  echo ""
  local skipped=$(( total - deleted ))
  success "Deleted ${deleted} branch(es). Skipped ${skipped}."
}

# ── gt version ──────────────────────────────────────────────────────────────
cmd_version() {
  echo "git-tool (gt) ${GT_VERSION}"
}

# ── Push Helper ──────────────────────────────────────────────────────────────
push_branch() {
  local branch="$1"
  local push_cmd
  if git rev-parse --verify --quiet "refs/remotes/origin/${branch}" &>/dev/null; then
    push_cmd="git push"
  else
    push_cmd="git push -u origin ${branch}"
  fi

  if ! $push_cmd 2>&1; then
    # Check if local branch has diverged from remote (e.g. after rebase)
    local local_base remote_base
    local_base=$(git merge-base HEAD "refs/remotes/origin/${branch}" 2>/dev/null || true)
    remote_base=$(git rev-parse "refs/remotes/origin/${branch}" 2>/dev/null || true)

    if [[ -n "$local_base" && "$local_base" != "$remote_base" ]]; then
      # Diverged — likely after a rebase, safe to force push
      warn "Branch has diverged from remote (likely after rebase)."
      local choice
      choice=$(gum choose "Force push (--force-with-lease)" "Abort" --header "Push was rejected:")
      if [[ "$choice" == "Force push (--force-with-lease)" ]]; then
        if ! git push --force-with-lease; then
          die "Force push failed."
        fi
      else
        info "Aborted."
        return
      fi
    else
      # Not diverged — try pull --rebase then push again
      info "Push rejected. Pulling with rebase..."
      if git pull --rebase; then
        if ! $push_cmd; then
          die "Push failed after pull. Resolve manually."
        fi
      else
        die "Pull --rebase failed. Resolve conflicts and push manually."
      fi
    fi
  fi
  success "Pushed to ${BOLD}origin/${branch}${RESET}"
}

# ── Main ─────────────────────────────────────────────────────────────────────
case "${1:-}" in
  branch)  check_deps; cmd_branch ;;
  push)    check_deps; cmd_push ;;
  message) check_deps; cmd_message ;;
  rebase)  cmd_rebase ;;
  status)  cmd_status ;;
  cleanup) check_deps; cmd_cleanup ;;
  version|--version|-v) cmd_version ;;
  *)
    echo -e "${BOLD}git-tool (gt)${RESET} ${GT_VERSION}"
    echo ""
    echo -e "  ${GREEN}gt branch${RESET}    Create a new branch off the default branch"
    echo -e "  ${GREEN}gt push${RESET}      Stage, commit with AI message, and push"
    echo -e "  ${GREEN}gt message${RESET}   Generate a commit message from current changes"
    echo -e "  ${GREEN}gt rebase${RESET}    Rebase current branch onto default branch"
    echo -e "  ${GREEN}gt status${RESET}    Show current branch overview"
    echo -e "  ${GREEN}gt cleanup${RESET}      Delete branches already merged or removed from remote"
    echo -e "  ${GREEN}gt version${RESET}      Show current version"
    echo -e "  ${GREEN}gt self-update${RESET}   Update gt to the latest version"
    echo ""
    ;;
esac
