#!/usr/bin/env bash
set -uo pipefail

# gt — Git Tool CLI
# Streamlines the git branch-commit-push workflow with AI-generated commit messages.

GT_VERSION="v2026.03.27"

# ── Colors & Styles ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Helpers ──────────────────────────────────────────────────────────────────
die() { echo -e "${RED}error:${RESET} $*" >&2; exit 1; }
info() { echo -e "${BLUE}▸${RESET} $*"; }
success() { echo -e "${GREEN}✓${RESET} $*"; }
warn() { echo -e "${YELLOW}⚠${RESET} $*"; }

# ── Configuration ───────────────────────────────────────────────────────────
GT_CONFIG_DIR="${HOME}/.config/git-tool"
GT_CONFIG_FILE="${GT_CONFIG_DIR}/config"

load_config() {
  GT_AI_CLI=""
  GT_AI_MODEL=""
  if [[ -f "$GT_CONFIG_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$GT_CONFIG_FILE"
  fi
}

ensure_ai_configured() {
  load_config
  if [[ -z "$GT_AI_CLI" || -z "$GT_AI_MODEL" ]]; then
    info "No AI tool configured."
    cmd_configure
    load_config
    [[ -z "$GT_AI_CLI" ]] && die "AI tool not configured. Run 'gt configure'."
  fi

  # Verify the configured tool is still installed
  if ! command -v "$GT_AI_CLI" &>/dev/null; then
    echo -e "${RED}Configured AI tool '${GT_AI_CLI}' is not installed.${RESET}"
    _show_install_instructions "$GT_AI_CLI"
    echo ""
    info "Run 'gt configure' to choose a different tool."
    exit 1
  fi
}

_show_install_instructions() {
  case "$1" in
    claude)   echo "  Install: brew install claude  (or see https://docs.anthropic.com/en/docs/claude-cli)" ;;
    codex)    echo "  Install: npm i -g @openai/codex  (or see https://developers.openai.com/codex/)" ;;
    opencode) echo "  Install: see https://opencode.ai" ;;
    gemini)   echo "  Install: npm i -g @google/gemini-cli  (or see https://google-gemini.github.io/gemini-cli/)" ;;
  esac
}

# ── Dependency Check ─────────────────────────────────────────────────────────
check_deps() {
  if ! command -v gum &>/dev/null; then
    echo -e "${RED}Missing dependency: gum${RESET}"
    echo "  Install: brew install gum  (or see https://github.com/charmbracelet/gum)"
    exit 1
  fi
}

# ── Git Guards ───────────────────────────────────────────────────────────────
assert_git_repo() {
  git rev-parse --is-inside-work-tree &>/dev/null || die "Not a git repository."
}

assert_remote_origin() {
  git remote get-url origin &>/dev/null || die "No remote 'origin' configured."
}

assert_not_detached() {
  local head
  head=$(git symbolic-ref --short HEAD 2>/dev/null) || die "HEAD is detached. Create or switch to a branch first."
}

# ── Ticket ID Extraction ────────────────────────────────────────────────────
extract_ticket_id() {
  local input="$1"
  if [[ "$input" =~ ([A-Z]+-[0-9]+) ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

# ── gt configure ─────────────────────────────────────────────────────────────
cmd_configure() {
  # 1. Choose AI CLI tool
  local tool
  tool=$(gum choose "claude" "codex" "opencode" "gemini" --header "Select AI CLI tool:") || die "Selection cancelled."
  [[ -z "$tool" ]] && die "No tool selected."

  # 2. Validate the tool is installed
  if ! command -v "$tool" &>/dev/null; then
    echo -e "${RED}${tool} is not installed.${RESET}"
    _show_install_instructions "$tool"
    exit 1
  fi

  # 3. Get available models
  local models_tmpfile
  models_tmpfile=$(mktemp /tmp/gt-models.XXXXXX)
  local models_prompt="List your available model names that work with the -m/--model flag, one per line, no explanations."

  local query_ok=0
  gum spin --spinner dot --title "Querying ${tool} for models..." -- \
    bash -c '
      case "$1" in
        claude)   claude -p "$2" > "$3" 2>/dev/null ;;
        codex)    codex exec "$2" > "$3" 2>/dev/null ;;
        opencode) opencode models > "$3" 2>/dev/null ;;
        gemini)   gemini -p "$2" > "$3" 2>/dev/null ;;
      esac
    ' _ "$tool" "$models_prompt" "$models_tmpfile" && query_ok=1

  local model_list=()
  if [[ $query_ok -eq 1 && -s "$models_tmpfile" ]]; then
    while IFS= read -r line; do
      line=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
      [[ -z "$line" ]] && continue
      [[ "$line" =~ ^[-#*] ]] && continue
      [[ ${#line} -gt 80 ]] && continue
      model_list+=("$line")
    done < "$models_tmpfile"
  fi
  rm -f "$models_tmpfile"

  # 4. Let user pick a model
  local model
  if [[ ${#model_list[@]} -gt 0 ]]; then
    model=$(printf "%s\n" "${model_list[@]}" | gum choose --header "Select model:") || die "Selection cancelled."
  else
    warn "Could not retrieve model list. Enter model name manually."
    model=$(gum input --placeholder "Model name (e.g. haiku, gpt-4o, gemini-2.5-flash)") || die "Input cancelled."
  fi
  [[ -z "$model" ]] && die "No model selected."

  # 5. Save config
  mkdir -p "$GT_CONFIG_DIR"
  cat > "$GT_CONFIG_FILE" <<EOF
GT_AI_CLI="${tool}"
GT_AI_MODEL="${model}"
EOF

  # 6. Confirm
  success "Configured: ${BOLD}${tool}${RESET} with model ${BOLD}${model}${RESET}"
}

# ── gt branch ────────────────────────────────────────────────────────────────
cmd_branch() {
  assert_git_repo
  assert_remote_origin

  # 1. Detect default branch
  local default_branch
  default_branch=$(gum spin --spinner dot --title "Detecting default branch..." -- \
    bash -c 'git remote show origin 2>/dev/null | grep "HEAD branch" | awk "{print \$NF}"')
  [[ -z "$default_branch" ]] && die "Could not detect default branch from origin."
  info "Default branch: ${BOLD}${default_branch}${RESET}"

  # 2. Stash if dirty
  local stashed=0
  if [[ -n $(git status --porcelain) ]]; then
    gum spin --spinner dot --title "Stashing uncommitted changes..." -- \
      git stash push -m "gt-auto-stash"
    stashed=1
  fi

  # 3. Switch to default branch and pull
  gum spin --spinner dot --title "Switching to ${default_branch} and pulling latest..." -- \
    bash -c 'git checkout "$1" 2>&1 && git pull 2>&1' _ "$default_branch"

  # 4. Prompt for branch name
  local raw_name
  raw_name=$(gum input --placeholder "Branch name (e.g. ID-4567 refactor order flow)")
  [[ -z "$raw_name" ]] && die "No branch name provided."

  # 5. Convert to valid branch name
  local ticket_id branch_name
  ticket_id=$(extract_ticket_id "$raw_name")

  # Strip ticket ID from the rest for lowercasing
  local rest="$raw_name"
  if [[ -n "$ticket_id" ]]; then
    rest="${raw_name:${#ticket_id}}"
  fi

  # Lowercase the rest, replace spaces/invalid chars with dashes
  rest=$(echo "$rest" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._/-]/-/g' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//')

  if [[ -n "$ticket_id" ]]; then
    branch_name="${ticket_id}-${rest}"
  else
    branch_name="$rest"
  fi

  # Clean up trailing dashes
  branch_name=$(echo "$branch_name" | sed 's/-$//')

  [[ -z "$branch_name" ]] && die "Could not derive a valid branch name."
  info "Creating branch: ${BOLD}${branch_name}${RESET}"

  # 6. Create and switch to new branch
  git checkout -b "$branch_name" &>/dev/null

  # 7. Pop stash if needed
  if [[ $stashed -eq 1 ]]; then
    info "Restoring stashed changes..."
    if ! git stash pop &>/dev/null; then
      warn "Merge conflicts occurred while restoring stashed changes."
      warn "Resolve conflicts manually, then run: git stash drop"
    fi
  fi

  success "On new branch ${BOLD}${branch_name}${RESET}"
}

# ── gt push ──────────────────────────────────────────────────────────────────
cmd_push() {
  assert_git_repo
  assert_remote_origin
  assert_not_detached

  local branch
  branch=$(git symbolic-ref --short HEAD)

  # 1. Detect changes
  local status_output
  status_output=$(git status --porcelain)

  if [[ -z "$status_output" ]]; then
    # 2. No changes — check for unpushed commits
    local unpushed
    unpushed=$(git log --oneline "@{upstream}..HEAD" 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$unpushed" -gt 0 ]]; then
      local choice
      choice=$(gum choose "Yes" "Abort" --header "No changes to commit. Push ${unpushed} unpushed commit(s)?")
      if [[ "$choice" == "Yes" ]]; then
        push_branch "$branch"
        return
      else
        info "Aborted."
        return
      fi
    else
      die "No changes to commit and no unpushed commits."
    fi
  fi

  # 3. Interactive file staging — build display labels with status icons
  local files=()
  local labels=()
  while IFS= read -r line; do
    local status="${line:0:2}"
    local fname="${line:3}"
    files+=("$fname")

    local tag
    case "$status" in
      " M"|"M "|"MM") tag="modified" ;;
      " D"|"D ")       tag="deleted" ;;
      "??")            tag="new" ;;
      " A"|"A ")       tag="added" ;;
      " R"|"R ")       tag="renamed" ;;
      " C"|"C ")       tag="copied" ;;
      *)               tag="changed" ;;
    esac
    labels+=("${fname} (${tag})")
  done <<< "$status_output"

  local choices=("All files")
  choices+=("${labels[@]}")

  local selected
  selected=$(gum choose --no-limit --selected="All files" --header "Select files to stage:" -- "${choices[@]}") || die "File selection cancelled."

  [[ -z "$selected" ]] && die "No files selected. Aborting."

  if echo "$selected" | grep -q "^All files$"; then
    git add -A
    info "Staged all files."
  else
    # Extract filenames back from the selected labels — strip trailing " (tag)"
    while IFS= read -r label; do
      local file="${label% (*}"
      git add -- "$file"
    done <<< "$selected"
    local count
    count=$(echo "$selected" | wc -l | tr -d ' ')
    info "Staged ${count} file(s)."
  fi

  # 4. Check that we have a non-empty diff
  local diff_output
  diff_output=$(git diff --staged)
  if [[ -z "$diff_output" ]]; then
    warn "Staged diff is empty. Nothing to commit."
    git reset HEAD -- . &>/dev/null
    return
  fi

  # Generate commit message (with retry loop)
  local commit_msg
  while true; do
    commit_msg=$(cmd_message)
    [[ -z "$commit_msg" ]] && die "Failed to generate commit message."

    echo ""
    echo -e "${BOLD}Commit message:${RESET}"
    echo -e "${DIM}─────────────────────────────────────────${RESET}"
    echo "$commit_msg"
    echo -e "${DIM}─────────────────────────────────────────${RESET}"
    echo ""

    local action
    action=$(gum choose "Accept" "Edit" "Regenerate" "Cancel" --header "What would you like to do?")

    case "$action" in
      Accept)
        break
        ;;
      Edit)
        local tmpfile
        tmpfile=$(mktemp /tmp/gt-commit-msg.XXXXXX)
        echo "$commit_msg" > "$tmpfile"
        ${EDITOR:-vi} "$tmpfile"
        commit_msg=$(cat "$tmpfile")
        rm -f "$tmpfile"
        [[ -z "$commit_msg" ]] && die "Empty commit message. Aborting."
        break
        ;;
      Regenerate)
        info "Regenerating commit message..."
        continue
        ;;
      Cancel)
        info "Unstaging files..."
        git reset HEAD -- . &>/dev/null
        info "Aborted."
        return
        ;;
    esac
  done

  # 6. Pull remote changes before committing (rebase to keep history clean)
  if git rev-parse --verify --quiet "@{upstream}" &>/dev/null; then
    local remote_ahead
    remote_ahead=$(git rev-list --count "HEAD..@{upstream}" 2>/dev/null || echo "0")
    if [[ "$remote_ahead" -gt 0 ]]; then
      git stash push -m "gt-pre-pull-stash" --keep-index &>/dev/null
      if ! gum spin --spinner dot --title "Pulling ${remote_ahead} remote change(s)..." -- git pull --rebase 2>&1; then
        warn "Pull failed. Restoring your changes..."
        git rebase --abort &>/dev/null
        git stash pop &>/dev/null
        die "Could not pull remote changes. Resolve manually."
      fi
      git stash pop &>/dev/null || true
    fi
  fi

  # 7. Commit
  if ! git commit -m "$commit_msg"; then
    die "Commit failed. Check for pre-commit hook errors or other issues."
  fi
  success "Committed."

  # 8. Push
  push_branch "$branch"
}

# ── gt message ───────────────────────────────────────────────────────────────
cmd_message() {
  assert_git_repo
  ensure_ai_configured

  local branch_name
  branch_name=$(git branch --show-current)

  local jira_id
  jira_id=$(echo "$branch_name" | grep -oE '[A-Z]+-[0-9]+' | head -n 1 || true)

  # Get staged changes, fall back to unstaged
  local staged_diff unstaged_diff diff_to_analyze
  staged_diff=$(git diff --cached)
  unstaged_diff=$(git diff)

  if [[ -n "$staged_diff" ]]; then
    diff_to_analyze="$staged_diff"
  elif [[ -n "$unstaged_diff" ]]; then
    diff_to_analyze="$unstaged_diff"
  else
    echo "error: No changes to summarize" >&2
    return 1
  fi

  # Recent commits for style context
  local recent_commits
  recent_commits=$(git log --oneline -5 2>/dev/null || true)

  local prompt="Generate a concise git commit message based on the diff below.

CRITICAL: Your response must contain ONLY the commit message itself - no explanations, no preamble, no code blocks, no markdown formatting.

Requirements:
- Single line, 1-2 sentences maximum
- Start with lowercase verb (add/fix/update/refactor/remove)
- Focus on what changed and why
- Be specific and concise
- Do NOT include any ticket/issue prefixes (like JIRA-123)
- Do NOT use markdown or code formatting

Recent commits for style reference:
${recent_commits}

Changes to summarize:
${diff_to_analyze}"

  local tmpfile
  tmpfile=$(mktemp /tmp/gt-message.XXXXXX)

  local errfile
  errfile=$(mktemp /tmp/gt-ai-err.XXXXXX)

  gum spin --spinner dot --title "Generating commit message..." -- \
    bash -c '
      case "$1" in
        claude)   claude -p --model "$2" "$3" > "$4" 2>"$5" ;;
        codex)    codex exec -m "$2" "$3" > "$4" 2>"$5" ;;
        opencode) opencode run -q -m "$2" "$3" > "$4" 2>"$5" ;;
        gemini)   gemini -p -m "$2" "$3" > "$4" 2>"$5" ;;
      esac
    ' _ "$GT_AI_CLI" "$GT_AI_MODEL" "$prompt" "$tmpfile" "$errfile" || {
    local err_output
    err_output=$(cat "$errfile")
    rm -f "$tmpfile" "$errfile"
    if [[ -n "$err_output" ]]; then
      echo -e "${RED}${GT_AI_CLI} error:${RESET}" >&2
      echo "$err_output" >&2
    else
      echo "error: AI CLI failed" >&2
    fi
    return 1
  }
  rm -f "$errfile"

  local raw_output
  raw_output=$(cat "$tmpfile")
  rm -f "$tmpfile"

  if [[ -z "$raw_output" ]]; then
    echo "error: AI CLI returned empty output" >&2
    return 1
  fi

  # Clean up the output
  local commit_message
  commit_message=$(echo "$raw_output" | \
    grep -v -i -E '(here|based on|following|git diff|commit message:)' | \
    grep -v '```' | \
    sed -E 's/^[A-Z]+-[0-9]+:[[:space:]]*//' | \
    grep -v '^[[:space:]]*$' | \
    awk 'length > 20' | \
    head -n 1 | \
    sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | \
    sed 's/^`*//;s/`*$//')

  # Fallback: first non-empty line
  if [[ -z "$commit_message" ]]; then
    commit_message=$(echo "$raw_output" | grep -v '^[[:space:]]*$' | head -n 1 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
  fi

  # Prefix with Jira ID if found
  if [[ -n "$jira_id" ]]; then
    commit_message="${jira_id}: ${commit_message}"
  fi

  # Output: no trailing newline if piped
  if [[ -t 1 ]]; then
    echo "$commit_message"
  else
    printf "%s" "$commit_message"
  fi
}

# ── gt rebase ────────────────────────────────────────────────────────────────
cmd_rebase() {
  assert_git_repo
  assert_remote_origin
  assert_not_detached

  local branch
  branch=$(git symbolic-ref --short HEAD)

  # Detect default branch
  local default_branch
  default_branch=$(gum spin --spinner dot --title "Detecting default branch..." -- \
    bash -c 'git remote show origin 2>/dev/null | grep "HEAD branch" | awk "{print \$NF}"')
  [[ -z "$default_branch" ]] && die "Could not detect default branch from origin."

  [[ "$branch" == "$default_branch" ]] && die "Already on ${default_branch}. Switch to a feature branch first."

  # Fetch latest
  gum spin --spinner dot --title "Fetching latest ${default_branch}..." -- \
    git fetch origin "$default_branch"

  # Check if rebase is needed
  local behind
  behind=$(git rev-list --count "HEAD..origin/${default_branch}")
  if [[ "$behind" -eq 0 ]]; then
    success "Already up to date with ${BOLD}${default_branch}${RESET}."
    return
  fi

  # Auto-stash if dirty
  local stashed=0
  if [[ -n $(git status --porcelain) ]]; then
    gum spin --spinner dot --title "Stashing uncommitted changes..." -- \
      git stash push -m "gt-auto-stash-rebase"
    stashed=1
  fi

  info "Rebasing onto ${BOLD}${default_branch}${RESET} (${behind} new commit(s))..."

  # Attempt rebase
  if git rebase "origin/${default_branch}" &>/dev/null; then
    success "Rebased successfully onto ${BOLD}${default_branch}${RESET}."
    if [[ $stashed -eq 1 ]]; then
      info "Restoring stashed changes..."
      if ! git stash pop &>/dev/null; then
        warn "Conflicts while restoring stashed changes. Resolve manually, then: git stash drop"
      fi
    fi
  else
    # Conflicts detected
    warn "Rebase conflicts detected."
    echo ""

    local conflict_files
    conflict_files=$(git diff --name-only --diff-filter=U 2>/dev/null)
    if [[ -z "$conflict_files" ]]; then
      conflict_files=$(git status --porcelain | grep '^UU\|^AA\|^DU\|^UD' | awk '{print $2}')
    fi

    if [[ -n "$conflict_files" ]]; then
      echo -e "${BOLD}Conflicting files:${RESET}"
      echo "$conflict_files" | while IFS= read -r f; do
        echo -e "  ${RED}•${RESET} $f"
      done
      echo ""
    fi

    local tool
    tool=$(gum choose "Claude Code" "Codex" "Abort rebase" --header "Resolve conflicts with:")

    local resolve_prompt="You are in the middle of a git rebase of branch '${branch}' onto 'origin/${default_branch}'.

The following files have merge conflicts:
${conflict_files}

Resolve all merge conflicts in these files. Look at the conflict markers (<<<<<<< HEAD, =======, >>>>>>> ...) and choose the correct resolution by understanding both sides. After resolving, stage the files with 'git add' and run 'git rebase --continue'. If further conflicts arise, resolve those too until the rebase completes. Prefer the incoming changes but preserve new functionality from the feature branch."

    case "$tool" in
      "Claude Code")
        info "Launching Claude Code to resolve conflicts..."
        claude "$resolve_prompt"
        if [[ $stashed -eq 1 ]]; then
          info "Restoring stashed changes..."
          git stash pop &>/dev/null || warn "Conflicts while restoring stash. Resolve manually, then: git stash drop"
        fi
        ;;
      "Codex")
        info "Launching Codex to resolve conflicts..."
        codex "$resolve_prompt"
        if [[ $stashed -eq 1 ]]; then
          info "Restoring stashed changes..."
          git stash pop &>/dev/null || warn "Conflicts while restoring stash. Resolve manually, then: git stash drop"
        fi
        ;;
      "Abort rebase")
        git rebase --abort 2>/dev/null
        info "Rebase aborted. Branch is unchanged."
        if [[ $stashed -eq 1 ]]; then
          info "Restoring stashed changes..."
          git stash pop &>/dev/null || warn "Conflicts while restoring stash. Resolve manually, then: git stash drop"
        fi
        ;;
    esac
  fi
}

# ── gt status ────────────────────────────────────────────────────────────────
cmd_status() {
  assert_git_repo
  assert_not_detached

  local branch
  branch=$(git symbolic-ref --short HEAD)

  local ticket_id
  ticket_id=$(extract_ticket_id "$branch")

  local dirty
  dirty=$(git status --porcelain | wc -l | tr -d ' ')

  local unpushed
  if git rev-parse --verify --quiet "@{upstream}" &>/dev/null; then
    unpushed=$(git log --oneline "@{upstream}..HEAD" 2>/dev/null | wc -l | tr -d ' ')
  else
    unpushed="—"
  fi

  local last_commit
  last_commit=$(git log -1 --pretty=format:'%s' 2>/dev/null || echo "(no commits)")

  echo ""
  echo -e "${BOLD}Branch:${RESET}    ${CYAN}${branch}${RESET}"
  if [[ -n "$ticket_id" ]]; then
    echo -e "${BOLD}Ticket:${RESET}    ${YELLOW}${ticket_id}${RESET}"
  fi
  echo -e "${BOLD}Dirty:${RESET}     ${dirty} file(s)"
  echo -e "${BOLD}Unpushed:${RESET}  ${unpushed} commit(s)"
  echo -e "${BOLD}Last:${RESET}      ${DIM}${last_commit}${RESET}"
  echo ""
}

# ── gt cleanup ────────────────────────────────────────────────────────────────
cmd_cleanup() {
  assert_git_repo
  assert_remote_origin
  assert_not_detached

  local branch
  branch=$(git symbolic-ref --short HEAD)

  # Detect default branch and fetch in one spinner
  local default_branch
  default_branch=$(gum spin --spinner dot --title "Fetching and pruning remote references..." -- \
    bash -c 'git fetch --prune &>/dev/null; git remote show origin 2>/dev/null | grep "HEAD branch" | awk "{print \$NF}"')
  [[ -z "$default_branch" ]] && die "Could not detect default branch from origin."

  # Use the remote ref for merge checks — local default branch may be stale
  local remote_default="origin/${default_branch}"

  # Get merged branches (excluding default)
  local merged_branches=()
  while IFS= read -r b; do
    [[ -z "$b" ]] && continue
    [[ "$b" == "$default_branch" ]] && continue
    merged_branches+=("$b")
  done < <(git branch --merged "$remote_default" --format='%(refname:short)')

  # Get all local branches (excluding default)
  local all_branches=()
  while IFS= read -r b; do
    [[ -z "$b" ]] && continue
    [[ "$b" == "$default_branch" ]] && continue
    all_branches+=("$b")
  done < <(git branch --format='%(refname:short)')

  # Categorize branches
  local safe_to_delete=()
  local merged_remote_exists=()
  local unmerged_remote_gone=()

  for b in "${all_branches[@]}"; do
    local is_merged=0
    for m in "${merged_branches[@]}"; do
      if [[ "$b" == "$m" ]]; then
        is_merged=1
        break
      fi
    done

    # Detect squash merges: create a temp squash commit and check
    # if its patch-id already exists in the default branch
    if [[ $is_merged -eq 0 ]]; then
      local mb sq
      mb=$(git merge-base "$remote_default" "$b" 2>/dev/null || true)
      if [[ -n "$mb" ]]; then
        sq=$(git commit-tree "${b}^{tree}" -p "$mb" -m "temp" 2>/dev/null || true)
        if [[ -n "$sq" ]] && ! git cherry "$remote_default" "$sq" 2>/dev/null | grep -q "^+"; then
          is_merged=1
        fi
      fi
    fi

    local remote_exists=0
    if git rev-parse --verify --quiet "refs/remotes/origin/${b}" &>/dev/null; then
      remote_exists=1
    fi

    if [[ $is_merged -eq 1 && $remote_exists -eq 0 ]]; then
      safe_to_delete+=("$b")
    elif [[ $is_merged -eq 1 && $remote_exists -eq 1 ]]; then
      merged_remote_exists+=("$b")
    elif [[ $is_merged -eq 0 && $remote_exists -eq 0 ]]; then
      unmerged_remote_gone+=("$b")
    fi
    # Not merged + remote exists = active, skip
  done

  local total=$(( ${#safe_to_delete[@]} + ${#merged_remote_exists[@]} + ${#unmerged_remote_gone[@]} ))

  if [[ $total -eq 0 ]]; then
    success "Nothing to clean up. All branches look active."
    return
  fi

  # Display summary
  echo ""
  echo -e "${BOLD}Branch cleanup summary:${RESET}"
  echo -e "  ${GREEN}Safe to delete (merged, remote gone):${RESET}    ${#safe_to_delete[@]}"
  echo -e "  ${YELLOW}Merged but remote exists:${RESET}                ${#merged_remote_exists[@]}"
  echo -e "  ${RED}Unmerged but remote gone:${RESET}                ${#unmerged_remote_gone[@]}"
  echo ""

  local deleted=0

  # Helper: switch to default branch if we're about to delete the current one
  _ensure_not_on_branch() {
    local target="$1"
    if [[ "$(git symbolic-ref --short HEAD)" == "$target" ]]; then
      info "Switching to ${BOLD}${default_branch}${RESET} before deleting current branch..."
      git checkout "$default_branch" &>/dev/null
      git pull --ff-only &>/dev/null || true
    fi
  }

  # Category 1: Safe to delete (merged + remote gone)
  if [[ ${#safe_to_delete[@]} -gt 0 ]]; then
    echo -e "${GREEN}${BOLD}── Safe to delete (merged, remote gone) ──${RESET}"
    local selected_csv
    selected_csv=$(printf "%s," "${safe_to_delete[@]}")
    selected_csv="${selected_csv%,}"

    local chosen
    chosen=$(printf "%s\n" "${safe_to_delete[@]}" | gum choose --no-limit --selected="$selected_csv" --header "Select branches to delete:") || true

    if [[ -n "$chosen" ]]; then
      while IFS= read -r b; do
        [[ -z "$b" ]] && continue
        _ensure_not_on_branch "$b"
        if git branch -D "$b" &>/dev/null; then
          info "Deleted ${BOLD}${b}${RESET}"
          deleted=$(( deleted + 1 ))
        else
          warn "Failed to delete ${BOLD}${b}${RESET}"
        fi
      done <<< "$chosen"
    fi
    echo ""
  fi

  # Category 2: Merged but remote still exists
  if [[ ${#merged_remote_exists[@]} -gt 0 ]]; then
    echo -e "${YELLOW}${BOLD}── Merged but remote still exists ──${RESET}"
    for b in "${merged_remote_exists[@]}"; do
      local action
      action=$(gum choose "Delete local only" "Delete local + remote" "Skip" --header "Branch: ${b}") || true

      case "$action" in
        "Delete local only")
          _ensure_not_on_branch "$b"
          if git branch -D "$b" &>/dev/null; then
            info "Deleted local ${BOLD}${b}${RESET}"
            deleted=$(( deleted + 1 ))
          else
            warn "Failed to delete ${BOLD}${b}${RESET}"
          fi
          ;;
        "Delete local + remote")
          _ensure_not_on_branch "$b"
          if git branch -D "$b" &>/dev/null; then
            info "Deleted local ${BOLD}${b}${RESET}"
            deleted=$(( deleted + 1 ))
          else
            warn "Failed to delete local ${BOLD}${b}${RESET}"
          fi
          if git push origin --delete "$b" &>/dev/null; then
            info "Deleted remote ${BOLD}origin/${b}${RESET}"
          else
            warn "Failed to delete remote ${BOLD}origin/${b}${RESET}"
          fi
          ;;
        *)
          ;;
      esac
    done
    echo ""
  fi

  # Category 3: Unmerged but remote gone
  if [[ ${#unmerged_remote_gone[@]} -gt 0 ]]; then
    echo -e "${RED}${BOLD}── Unmerged but remote gone (caution) ──${RESET}"
    # Build labels with commit counts; keep parallel array for name lookup
    local labels=()
    local label_branches=()
    for b in "${unmerged_remote_gone[@]}"; do
      local ahead
      ahead=$(git rev-list --count "${remote_default}..${b}" 2>/dev/null || echo "?")
      labels+=("${b} (${ahead} commits ahead)")
      label_branches+=("$b")
    done

    local chosen
    chosen=$(printf "%s\n" "${labels[@]}" | gum choose --no-limit --header "Select branches to force-delete:") || true

    if [[ -n "$chosen" ]]; then
      while IFS= read -r label; do
        [[ -z "$label" ]] && continue
        # Find matching branch from parallel array
        local b=""
        for i in "${!labels[@]}"; do
          if [[ "${labels[$i]}" == "$label" ]]; then
            b="${label_branches[$i]}"
            break
          fi
        done
        [[ -z "$b" ]] && continue
        _ensure_not_on_branch "$b"
        if git branch -D "$b" &>/dev/null; then
          info "Force-deleted ${BOLD}${b}${RESET}"
          deleted=$(( deleted + 1 ))
        else
          warn "Failed to delete ${BOLD}${b}${RESET}"
        fi
      done <<< "$chosen"
    fi
    echo ""
  fi

  # Final summary
  echo ""
  local skipped=$(( total - deleted ))
  success "Deleted ${deleted} branch(es). Skipped ${skipped}."
}

# ── gt pr ───────────────────────────────────────────────────────────────────
cmd_pr() {
  assert_git_repo
  assert_remote_origin
  assert_not_detached
  ensure_ai_configured

  local branch
  branch=$(git symbolic-ref --short HEAD)

  # Detect default branch
  local default_branch
  default_branch=$(gum spin --spinner dot --title "Detecting default branch..." -- \
    bash -c 'git remote show origin 2>/dev/null | grep "HEAD branch" | awk "{print \$NF}"')
  [[ -z "$default_branch" ]] && die "Could not detect default branch from origin."

  [[ "$branch" == "$default_branch" ]] && die "Already on ${default_branch}. Create a feature branch first."

  # Extract ticket ID from branch name
  local ticket_id
  ticket_id=$(extract_ticket_id "$branch")

  # Detect platform from remote URL
  local remote_url platform pr_cmd pr_label
  remote_url=$(git remote get-url origin)

  if [[ "$remote_url" == *github* ]]; then
    platform="github"
    pr_cmd="gh"
    pr_label="Pull Request"
  elif [[ "$remote_url" == *gitlab* ]]; then
    platform="gitlab"
    pr_cmd="glab"
    pr_label="Merge Request"
  else
    die "Could not detect platform from remote URL. Only GitHub and GitLab are supported."
  fi

  # Check for platform CLI
  if ! command -v "$pr_cmd" &>/dev/null; then
    echo -e "${RED}Missing dependency: ${pr_cmd}${RESET}"
    if [[ "$platform" == "github" ]]; then
      echo "  Install: brew install gh  (or see https://cli.github.com)"
    else
      echo "  Install: brew install glab  (or see https://gitlab.com/gitlab-org/cli)"
    fi
    exit 1
  fi

  # Auto-push if branch not on remote
  if ! git rev-parse --verify --quiet "refs/remotes/origin/${branch}" &>/dev/null; then
    gum spin --spinner dot --title "Pushing branch to origin..." -- \
      git push -u origin "$branch" 2>&1
  else
    # Push any unpushed commits
    local unpushed
    unpushed=$(git log --oneline "@{upstream}..HEAD" 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$unpushed" -gt 0 ]]; then
      gum spin --spinner dot --title "Pushing ${unpushed} unpushed commit(s)..." -- \
        git push 2>&1
    fi
  fi

  # Gather context for AI
  local commit_log
  commit_log=$(git log --oneline "${default_branch}..HEAD" 2>/dev/null)
  [[ -z "$commit_log" ]] && die "No commits ahead of ${default_branch}. Nothing to create a PR for."

  local diff_stat
  diff_stat=$(git diff --stat "${default_branch}..HEAD" 2>/dev/null)

  # Reserve space for ticket prefix in title
  local max_title_len=80
  if [[ -n "$ticket_id" ]]; then
    max_title_len=$(( 80 - ${#ticket_id} - 2 ))  # "ID-123: " prefix
  fi

  local prompt="Generate a pull request title and description based on the branch and commits below.

CRITICAL: Your response must follow this EXACT format with no other text:

TITLE: <title here>
DESCRIPTION:
<description here>

Requirements for TITLE:
- Maximum ${max_title_len} characters
- Start with lowercase verb (add/fix/update/refactor/remove)
- Be specific and concise
- Do NOT include any ticket/issue prefixes (like JIRA-123)

Requirements for DESCRIPTION:
- Use markdown formatting
- Start with a ## Summary section with 2-4 bullet points
- Add a ## Changes section listing key changes
- Keep it concise but informative
- Do NOT wrap in code blocks

Branch name: ${branch}

Commits:
${commit_log}

Diff stats:
${diff_stat}"

  # Generate PR content (with review loop)
  local title description
  while true; do
    local tmpfile
    tmpfile=$(mktemp /tmp/gt-pr.XXXXXX)

    local errfile
    errfile=$(mktemp /tmp/gt-ai-err.XXXXXX)

    gum spin --spinner dot --title "Generating ${pr_label} content..." -- \
      bash -c '
        case "$1" in
          claude)   claude -p --model "$2" "$3" > "$4" 2>"$5" ;;
          codex)    codex exec -m "$2" "$3" > "$4" 2>"$5" ;;
          opencode) opencode run -q -m "$2" "$3" > "$4" 2>"$5" ;;
          gemini)   gemini -p -m "$2" "$3" > "$4" 2>"$5" ;;
        esac
      ' _ "$GT_AI_CLI" "$GT_AI_MODEL" "$prompt" "$tmpfile" "$errfile" || {
      local err_output
      err_output=$(cat "$errfile")
      rm -f "$tmpfile" "$errfile"
      if [[ -n "$err_output" ]]; then
        echo -e "${RED}${GT_AI_CLI} error:${RESET}" >&2
        echo "$err_output" >&2
      fi
      die "AI CLI failed."
    }
    rm -f "$errfile"

    local raw_output
    raw_output=$(cat "$tmpfile")
    rm -f "$tmpfile"

    [[ -z "$raw_output" ]] && die "AI CLI returned empty output."

    # Parse title and description
    title=$(echo "$raw_output" | grep -m1 '^TITLE:' | sed 's/^TITLE:[[:space:]]*//')
    description=$(echo "$raw_output" | sed -n '/^DESCRIPTION:/,$ p' | tail -n +2)

    # Clean up
    title=$(echo "$title" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | head -c "$max_title_len")
    description=$(echo "$description" | sed 's/^[[:space:]]*$//' | sed '/./,$!d')

    [[ -z "$title" ]] && title="$(echo "$commit_log" | head -1 | head -c "$max_title_len")"

    # Prepend ticket ID
    if [[ -n "$ticket_id" ]]; then
      title="${ticket_id}: ${title}"
    fi
    [[ -z "$description" ]] && description="$(echo "$commit_log")"

    # Show preview
    echo ""
    echo -e "${BOLD}${pr_label}:${RESET}"
    echo -e "${DIM}─────────────────────────────────────────${RESET}"
    echo -e "${BOLD}Title:${RESET} ${title}"
    echo ""
    echo "$description"
    echo -e "${DIM}─────────────────────────────────────────${RESET}"
    echo ""

    local action
    action=$(gum choose "Accept" "Edit" "Regenerate" "Cancel" --header "What would you like to do?")

    case "$action" in
      Accept)
        break
        ;;
      Edit)
        local tmpfile_edit
        tmpfile_edit=$(mktemp /tmp/gt-pr-edit.XXXXXX)
        printf "TITLE: %s\n\n%s" "$title" "$description" > "$tmpfile_edit"
        ${EDITOR:-vi} "$tmpfile_edit"
        title=$(head -1 "$tmpfile_edit" | sed 's/^TITLE:[[:space:]]*//')
        description=$(tail -n +3 "$tmpfile_edit")
        rm -f "$tmpfile_edit"
        [[ -z "$title" ]] && die "Empty title. Aborting."
        break
        ;;
      Regenerate)
        continue
        ;;
      Cancel)
        info "Aborted."
        return
        ;;
    esac
  done

  # Create PR/MR
  local pr_tmpfile
  pr_tmpfile=$(mktemp /tmp/gt-pr-url.XXXXXX)

  if [[ "$platform" == "github" ]]; then
    gum spin --spinner dot --title "Creating ${pr_label}..." -- \
      bash -c 'gh pr create --base "$1" --title "$2" --body "$3" > "$4" 2>&1' \
      _ "$default_branch" "$title" "$description" "$pr_tmpfile"
  else
    gum spin --spinner dot --title "Creating ${pr_label}..." -- \
      bash -c 'glab mr create --target-branch "$1" --title "$2" --description "$3" --squash-before-merge --no-editor > "$4" 2>&1' \
      _ "$default_branch" "$title" "$description" "$pr_tmpfile"
  fi

  local pr_url
  pr_url=$(cat "$pr_tmpfile")
  rm -f "$pr_tmpfile"

  if [[ -z "$pr_url" ]]; then
    die "Failed to create ${pr_label}."
  fi

  # Extract URL from output (gh/glab may print extra text like update notices)
  local url
  if [[ "$platform" == "gitlab" ]]; then
    url=$(echo "$pr_url" | grep -oE 'https://[^ ]*/merge_requests/[0-9]+' | head -1)
  else
    url=$(echo "$pr_url" | grep -oE 'https://[^ ]*/pull/[0-9]+' | head -1)
  fi
  # Fallback: first URL in output
  [[ -z "$url" ]] && url=$(echo "$pr_url" | grep -oE 'https://[^ ]+' | head -1)

  echo ""
  success "Created ${pr_label}: ${BOLD}${url:-$pr_url}${RESET}"
}

# ── gt version ──────────────────────────────────────────────────────────────
cmd_version() {
  echo "git-tool (gt) ${GT_VERSION}"
}

# ── gt self-update ──────────────────────────────────────────────────────────
cmd_self_update() {
  local repo_url="https://raw.githubusercontent.com/KubaRocks/git-tool/main"

  # Detect install path
  local install_path
  install_path=$(which gt 2>/dev/null) || die "Could not find gt in PATH."
  info "Installed at: ${BOLD}${install_path}${RESET}"

  # Check current version
  info "Current version: ${BOLD}${GT_VERSION}${RESET}"

  # Fetch latest version
  local latest_version
  latest_version=$(curl -fsSL "${repo_url}/VERSION" 2>/dev/null) || die "Could not check for updates."
  latest_version=$(echo "$latest_version" | tr -d '[:space:]')

  if [[ "$GT_VERSION" == "$latest_version" ]]; then
    success "Already up to date."
    return
  fi

  info "New version available: ${BOLD}${latest_version}${RESET}"
  info "Updating: ${BOLD}${GT_VERSION}${RESET} → ${BOLD}${latest_version}${RESET}"

  # Download new version
  local use_sudo=""
  if [[ ! -w "$install_path" ]]; then
    use_sudo="sudo"
    warn "Requires sudo to write to ${install_path}"
  fi

  local tmpfile
  tmpfile=$(mktemp /tmp/gt-update.XXXXXX)
  if ! curl -fsSL "${repo_url}/gt" -o "$tmpfile" 2>/dev/null; then
    rm -f "$tmpfile"
    die "Failed to download update."
  fi

  $use_sudo cp "$tmpfile" "$install_path"
  $use_sudo chmod +x "$install_path"
  rm -f "$tmpfile"

  success "Updated gt to ${BOLD}${latest_version}${RESET}"

  # Update completions if installed
  _update_completions "$repo_url"

  echo ""
  echo -e "git-tool (gt) ${GT_VERSION} → ${latest_version}"

  # Exit immediately — the script on disk was just replaced, so bash must not
  # continue reading from the now-different file.
  exit 0
}

_update_completions() {
  local repo_url="$1"

  # Find installed completions
  local comp_file=""
  for dir in "$HOME/.zsh/completions" "$HOME/.local/share/zsh/completions"; do
    if [[ -f "${dir}/_gt" ]]; then
      comp_file="${dir}/_gt"
      break
    fi
  done

  [[ -z "$comp_file" ]] && return

  # Download to temp and compare
  local tmpfile
  tmpfile=$(mktemp /tmp/gt-comp.XXXXXX)
  if curl -fsSL "${repo_url}/completions/_gt" -o "$tmpfile" 2>/dev/null; then
    if ! diff -q "$comp_file" "$tmpfile" &>/dev/null; then
      cp "$tmpfile" "$comp_file"
      info "Updated zsh completions."
      warn "Run ${BOLD}exec zsh${RESET} to reload completions."
    fi
  fi
  rm -f "$tmpfile"
}

# ── Push Helper ──────────────────────────────────────────────────────────────
push_branch() {
  local branch="$1"
  local push_cmd
  if git rev-parse --verify --quiet "refs/remotes/origin/${branch}" &>/dev/null; then
    push_cmd="git push"
  else
    push_cmd="git push -u origin ${branch}"
  fi

  if ! gum spin --spinner dot --title "Pushing to origin/${branch}..." -- $push_cmd 2>&1; then
    # Check if local branch has diverged from remote (e.g. after rebase)
    local local_base remote_base
    local_base=$(git merge-base HEAD "refs/remotes/origin/${branch}" 2>/dev/null || true)
    remote_base=$(git rev-parse "refs/remotes/origin/${branch}" 2>/dev/null || true)

    if [[ -n "$local_base" && "$local_base" != "$remote_base" ]]; then
      # Diverged — likely after a rebase, safe to force push
      warn "Branch has diverged from remote (likely after rebase)."
      local choice
      choice=$(gum choose "Force push (--force-with-lease)" "Abort" --header "Push was rejected:")
      if [[ "$choice" == "Force push (--force-with-lease)" ]]; then
        if ! gum spin --spinner dot --title "Force pushing..." -- git push --force-with-lease 2>&1; then
          die "Force push failed."
        fi
      else
        info "Aborted."
        return
      fi
    else
      # Not diverged — try pull --rebase then push again
      if gum spin --spinner dot --title "Pulling with rebase..." -- git pull --rebase 2>&1; then
        if ! gum spin --spinner dot --title "Pushing to origin/${branch}..." -- $push_cmd 2>&1; then
          die "Push failed after pull. Resolve manually."
        fi
      else
        die "Pull --rebase failed. Resolve conflicts and push manually."
      fi
    fi
  fi
  success "Pushed to ${BOLD}origin/${branch}${RESET}"
}

# ── Main ─────────────────────────────────────────────────────────────────────
# Wrapped in a function so bash reads the entire script into memory before
# executing. This prevents parse errors when cmd_self_update replaces the
# script on disk mid-execution.
main() {
  case "${1:-}" in
    branch)  check_deps; cmd_branch ;;
    push)    check_deps; cmd_push ;;
    message) check_deps; cmd_message ;;
    rebase)  cmd_rebase ;;
    status)  cmd_status ;;
    cleanup) check_deps; cmd_cleanup ;;
    pr)      check_deps; cmd_pr ;;
    configure) check_deps; cmd_configure ;;
    self-update) cmd_self_update ;;
    version|--version|-v) cmd_version ;;
    *)
      echo -e "${BOLD}git-tool (gt)${RESET} ${GT_VERSION}"
      echo ""
      load_config
      if [[ -n "$GT_AI_CLI" && -n "$GT_AI_MODEL" ]]; then
        echo -e "  ${BOLD}AI:${RESET} ${CYAN}${GT_AI_CLI}${RESET} (model: ${CYAN}${GT_AI_MODEL}${RESET})"
      else
        echo -e "  ${BOLD}AI:${RESET} ${DIM}not configured${RESET}  ${DIM}— run ${RESET}${GREEN}gt configure${RESET}"
      fi
      echo ""
      echo -e "  ${GREEN}gt branch${RESET}       Create a new branch off the default branch"
      echo -e "  ${GREEN}gt push${RESET}        Stage, commit with AI message, and push"
      echo -e "  ${GREEN}gt message${RESET}     Generate a commit message from current changes"
      echo -e "  ${GREEN}gt rebase${RESET}      Rebase current branch onto default branch"
      echo -e "  ${GREEN}gt status${RESET}      Show current branch overview"
      echo -e "  ${GREEN}gt cleanup${RESET}     Delete branches already merged or removed from remote"
      echo -e "  ${GREEN}gt pr${RESET}          Create a pull/merge request with AI-generated description"
      echo -e "  ${GREEN}gt configure${RESET}   Choose AI CLI tool and model"
      echo -e "  ${GREEN}gt version${RESET}     Show current version"
      echo -e "  ${GREEN}gt self-update${RESET}  Update gt to the latest version"
      echo ""
      ;;
  esac
}

main "$@"
