#compdef gt

_gt() {
  local -a commands
  commands=(
    'branch:Create a new branch off the default branch'
    'cleanup:Delete branches already merged or removed from remote'
    'configure:Choose AI CLI tool and model'
    'pr:Create a pull/merge request with AI-generated description'
    'push:Stage, commit with AI message, and push'
    'message:Generate a commit message from current changes'
    'rebase:Rebase current branch onto default branch'
    'status:Show current branch overview'
    'self-update:Update gt to the latest version'
    'version:Show current version'
  )

  _arguments '1: :->command'

  case $state in
    command)
      _describe 'gt command' commands
      ;;
  esac
}

_gt "$@"
